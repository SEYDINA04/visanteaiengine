# Visanté AI Engine - Environment variables
# Copy to .env and set values.

# Required for LLM (question generation, RAG synthesis). Get key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here
# Alternative env name (used if GOOGLE_API_KEY is not set)
# GEMINI_API_KEY=your_api_key_here

# Optional: Render host (for docs / mobile app config reference; app uses request host by default)
# BASE_URL=https://visante-ai-engine.onrender.com

# Optional: override defaults
# ENVIRONMENT=development
# DEBUG=false
# CHROMA_PERSIST_DIRECTORY=./data/chroma
# RAG_TOP_K=5

